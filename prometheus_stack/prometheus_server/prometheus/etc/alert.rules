groups:
  - name: infrastructure_alerts
    rules:
      - alert: InstanceDown
        expr: up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Instance {{ $labels.instance }} unavailable"
          description: "Prometheus cann't get metrics from {{ $labels.instance }} for 1 minute."

      - alert: HighCpuUsage
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Hi CPU load on {{ $labels.instance }}"
          description: "CPU usage is  {{ $value | printf \"%.2f\" }}% for 5 minutes."

      - alert: OutOfMemory
        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100 < 10
        for: 2m
        labels:
          severity: warning
        annotations:
          summary: "RAM is low on {{ $labels.instance }}"
          description: "less than 10% of memory is available on (current value: {{ $value | printf \"%.2f\" }}%)."

      - alert: DiskSpaceFillingUp
        expr: (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100 < 15
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Disk space is running out: {{ $labels.instance }}"
          description: "There is less than 15% free space left on the / section."
