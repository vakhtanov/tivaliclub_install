map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}


server {

    listen 80;

    if ($scheme = "http") {

      return 301 https://$host$request_uri;
     }


    listen 443 ssl http2; # managed by Certbot
    # listen [::]:443 ssl ipv6only=on http2; # managed by Certbot



    server_name devopsdemo.ru; # managed by Certbot


    location / {
    proxy_pass http://192.168.0.3:11000$request_uri;

    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Port $server_port;
    proxy_set_header X-Forwarded-Scheme $scheme;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header Accept-Encoding "";
    proxy_set_header Host $host;

    proxy_set_header Early-Data $ssl_early_data;

    # Websocket
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;

    }

    # SSL configuration

    ssl_certificate /etc/letsencrypt/live/devopsdemo.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/devopsdemo.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
